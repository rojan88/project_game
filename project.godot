; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Monster Pact"
config/description="Top-down dodge-based action RPG with monster companions."
run/main_scene="res://scenes/main/test_arena.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

MonsterConfig="*res://scripts/monster_config.gd"
WeaponConfig="*res://scripts/weapon_config.gd"
SecondaryItemConfig="*res://scripts/secondary_item_config.gd"
GameState="*res://scripts/game_state.gd"
CombatEffects="*res://scripts/combat_effects.gd"
CompanionConfig="*res://scripts/companion_config.gd"
ItemConfig="*res://scripts/item_config.gd"
StageConfig="*res://scripts/stage_config.gd"

[display]

window/size/viewport_width=384
window/size/viewport_height=216
window/size/mode=2
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

